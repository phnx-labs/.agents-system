#!/bin/bash
# muqsit-cli -- unified human interface for AI agents
# Usage: muqsit <command> [args]
#
# Commands:
#   escalate "message"                 -- high-priority Telegram ping
#   notify "message" [--attach path]   -- Telegram message, optional image
#   call "message"                     -- Twilio phone call
#   screenshot                         -- full desktop capture, prints path

set -euo pipefail

CHAT_ID="6078999250"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENTS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
OPENCLAW_CONFIG="${HOME}/.openclaw/openclaw.json"
PHONE_CALL_DIR="${AGENTS_DIR}/skills/phone-call"

# Resolve bot token: use --bot <account> or default to main token
resolve_token() {
  local account="${1:-}"
  if [ -n "$account" ] && [ -f "$OPENCLAW_CONFIG" ]; then
    local token
    token=$(python3 -c "
import json, sys
c = json.load(open('${OPENCLAW_CONFIG}'))
accts = c.get('channels',{}).get('telegram',{}).get('accounts',{})
acct = accts.get('${account}', {})
t = acct.get('botToken', '')
if t: print(t)
else: print(c.get('channels',{}).get('telegram',{}).get('botToken',''))
" 2>/dev/null)
    echo "$token"
  elif [ -f "$OPENCLAW_CONFIG" ]; then
    python3 -c "
import json
c = json.load(open('${OPENCLAW_CONFIG}'))
print(c.get('channels',{}).get('telegram',{}).get('botToken',''))
" 2>/dev/null
  else
    echo ""
  fi
}

cmd_escalate() {
  local msg="$1"
  local bot="${2:-}"
  local token
  token=$(resolve_token "$bot")
  if [ -z "$token" ]; then
    echo "Error: no bot token found" >&2
    exit 1
  fi
  curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" \
    -d "chat_id=${CHAT_ID}" \
    -d "text=[URGENT] ${msg}" \
    -d "parse_mode=Markdown" > /dev/null
  echo "Escalated."
}

cmd_notify() {
  local msg=""
  local attach=""
  local bot=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --attach) attach="$2"; shift 2 ;;
      --bot) bot="$2"; shift 2 ;;
      *) msg="$1"; shift ;;
    esac
  done

  local token
  token=$(resolve_token "$bot")
  if [ -z "$token" ]; then
    echo "Error: no bot token found" >&2
    exit 1
  fi

  if [ -n "$attach" ] && [ -f "$attach" ]; then
    curl -s -X POST "https://api.telegram.org/bot${token}/sendPhoto" \
      -F "chat_id=${CHAT_ID}" \
      -F "photo=@${attach}" \
      -F "caption=${msg}" > /dev/null
  else
    curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" \
      -d "chat_id=${CHAT_ID}" \
      -d "text=${msg}" \
      -d "parse_mode=Markdown" > /dev/null
  fi
  echo "Sent."
}

cmd_call() {
  local msg="$1"
  if [ ! -f "${PHONE_CALL_DIR}/call.sh" ]; then
    echo "Error: phone-call skill not found at ${PHONE_CALL_DIR}" >&2
    exit 1
  fi
  bash "${PHONE_CALL_DIR}/call.sh" "$msg"
}

cmd_screenshot() {
  local filepath="/tmp/screen-$(date +%s).png"
  screencapture -x -m "$filepath"
  if [ -f "$filepath" ]; then
    echo "$filepath"
  else
    echo "Error: screenshot failed" >&2
    exit 1
  fi
}

# Main dispatch
case "${1:-}" in
  escalate)
    shift
    msg="${1:?Usage: muqsit escalate \"message\" [--bot account]}"
    bot=""
    [ "${2:-}" = "--bot" ] && bot="${3:-}"
    cmd_escalate "$msg" "$bot"
    ;;
  notify)
    shift
    cmd_notify "$@"
    ;;
  call)
    shift
    msg="${1:?Usage: muqsit call \"message\"}"
    cmd_call "$msg"
    ;;
  screenshot)
    cmd_screenshot
    ;;
  *)
    echo "Usage: muqsit <command> [args]"
    echo ""
    echo "Commands:"
    echo "  escalate \"message\" [--bot account]    High-priority Telegram ping"
    echo "  notify \"message\" [--attach path]      Telegram message, optional image"
    echo "  call \"message\"                        Twilio phone call"
    echo "  screenshot                             Full desktop capture, prints path"
    exit 1
    ;;
esac
